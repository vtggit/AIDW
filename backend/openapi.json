{
  "openapi": "3.1.0",
  "info": {
    "title": "AIDW",
    "version": "0.2.3"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health Check",
        "description": "Shallow liveness check \u2014 does not call dependencies.\n\nReturns app status, version, and build metadata.\nUse this for load balancer health checks and container liveness probes.",
        "operationId": "health_check_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/health/ready": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Readiness Check",
        "description": "Readiness check \u2014 verifies critical dependencies are reachable.\n\nTests database connectivity and reports dependency health.\nReturns status 'ok' only when all dependencies are healthy.\nUse this for container readiness probes and operational diagnostics.",
        "operationId": "readiness_check_api_health_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/health/version": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Route Api Health Version",
        "operationId": "route_api_health_version_api_health_version_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Get Me",
        "description": "Return the currently authenticated user's context.\n\nRequires a valid Bearer token.  The response contains normalised\nroles and groups derived from the IdP token claims.  Used by the\nfrontend to establish auth state at startup.",
        "operationId": "get_me_api_auth_me_get",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/config": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Get Auth Config",
        "description": "Public (unauthenticated) endpoint that exposes non-sensitive frontend\nauth configuration.\n\nOnly public client metadata is returned \u2014 no secrets, keys, or tokens.",
        "operationId": "get_auth_config_api_auth_config_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthConfigResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/audit": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Get Audit Log",
        "description": "List recent audit events. Requires admin role.\n\nOptionally filter by entity type and limit the number of results.",
        "operationId": "get_audit_log_api_audit_get",
        "parameters": [
          {
            "name": "entity_type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Entity Type"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "title": "Limit"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AuditEventResponse"
                  },
                  "title": "Response Get Audit Log Api Audit Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuditEventResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "entity_type": {
            "type": "string",
            "title": "Entity Type"
          },
          "entity_id": {
            "type": "string",
            "title": "Entity Id"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "actor_sub": {
            "type": "string",
            "title": "Actor Sub"
          },
          "actor_username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actor Username"
          },
          "actor_email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actor Email"
          },
          "actor_roles": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actor Roles"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "details": {
            "additionalProperties": true,
            "type": "object",
            "title": "Details"
          }
        },
        "type": "object",
        "required": [
          "id",
          "entity_type",
          "entity_id",
          "action",
          "actor_sub",
          "timestamp"
        ],
        "title": "AuditEventResponse",
        "description": "Audit event returned by the API."
      },
      "AuthConfigResponse": {
        "properties": {
          "authEnabled": {
            "type": "boolean",
            "title": "Authenabled",
            "description": "Whether authentication is enforced"
          },
          "authMode": {
            "type": "string",
            "title": "Authmode",
            "description": "Current auth mode (development/production)"
          },
          "issuer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Issuer",
            "description": "IdP issuer URL"
          },
          "clientId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clientid",
            "description": "OAuth client ID"
          },
          "audience": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Audience",
            "description": "Expected token audience"
          },
          "jwksUrl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Jwksurl",
            "description": "JWKS endpoint URL"
          },
          "algorithms": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Algorithms",
            "description": "Accepted JWT signature algorithms"
          }
        },
        "type": "object",
        "required": [
          "authEnabled",
          "authMode"
        ],
        "title": "AuthConfigResponse",
        "description": "Public auth configuration exposed to the frontend."
      },
      "AuthUser": {
        "properties": {
          "sub": {
            "type": "string",
            "title": "Sub",
            "description": "Unique user identifier (token subject)"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username",
            "description": "Preferred username or display name"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          },
          "roles": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Roles",
            "description": "Normalized application roles"
          },
          "groups": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Groups",
            "description": "Normalized IdP groups"
          },
          "raw_claims": {
            "additionalProperties": true,
            "type": "object",
            "title": "Raw Claims",
            "description": "Full token claims for future extension"
          }
        },
        "type": "object",
        "required": [
          "sub"
        ],
        "title": "AuthUser",
        "description": "Represents the currently authenticated user derived from token claims."
      },
      "DependencyStatus": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Dependency name"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "ok, error, or unavailable"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail",
            "description": "Optional diagnostic detail"
          }
        },
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "title": "DependencyStatus",
        "description": "Status of a single dependency (e.g. database)."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Service health status"
          },
          "app_version": {
            "type": "string",
            "title": "App Version",
            "description": "Application version string"
          },
          "service": {
            "type": "string",
            "title": "Service",
            "description": "Service identifier"
          },
          "git_sha": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Sha",
            "description": "Git commit SHA (build metadata)"
          },
          "build_timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Build Timestamp",
            "description": "ISO-8601 build timestamp (build metadata)"
          }
        },
        "type": "object",
        "required": [
          "status",
          "app_version",
          "service"
        ],
        "title": "HealthResponse",
        "description": "Response model for the shallow health check endpoint."
      },
      "MeResponse": {
        "properties": {
          "authenticated": {
            "type": "boolean",
            "title": "Authenticated",
            "default": true
          },
          "user": {
            "$ref": "#/components/schemas/AuthUser"
          }
        },
        "type": "object",
        "required": [
          "user"
        ],
        "title": "MeResponse",
        "description": "Response body for GET /api/auth/me."
      },
      "ReadinessResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Service readiness status"
          },
          "app_version": {
            "type": "string",
            "title": "App Version",
            "description": "Application version string"
          },
          "service": {
            "type": "string",
            "title": "Service",
            "description": "Service identifier"
          },
          "git_sha": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Sha",
            "description": "Git commit SHA (build metadata)"
          },
          "build_timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Build Timestamp",
            "description": "ISO-8601 build timestamp (build metadata)"
          },
          "dependencies": {
            "items": {
              "$ref": "#/components/schemas/DependencyStatus"
            },
            "type": "array",
            "title": "Dependencies",
            "description": "Status of critical dependencies"
          }
        },
        "type": "object",
        "required": [
          "status",
          "app_version",
          "service"
        ],
        "title": "ReadinessResponse",
        "description": "Response model for the readiness health check endpoint."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
