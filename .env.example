# AIDW deployment environment — copy to `.env` and fill in before `docker compose up`.
# docker-compose.yml reads these via ${VAR} interpolation. Variables with a default shown as
# ${VAR:-default} in the compose file may be omitted; the ones marked REQUIRED below have no
# default and must be set. This example file contains NO real secrets — do not commit a filled-in
# `.env` (it is gitignored).

# ---------------------------------------------------------------------------
# Database (REQUIRED — no defaults)
# ---------------------------------------------------------------------------
DB_NAME=aidw
DB_USER=aidw
DB_PASSWORD=change-me
# Host port publishing (optional; container ports are fixed)
DB_PORT_HOST=5432
BACKEND_PORT_HOST=9000
FRONTEND_PORT_HOST=8080

# ---------------------------------------------------------------------------
# Authentication (optional — dev-friendly defaults shown)
# ---------------------------------------------------------------------------
AUTH_ENABLED=true
AUTH_MODE=development
# Development bearer token accepted when AUTH_MODE=development. Replace for any shared deployment.
AUTH_DEV_TOKEN=dev-secret-token
AUTH_ISSUER=https://dev.example.com/realms/aicrm
AUTH_CLIENT_ID=aidw-backend
AUTH_AUDIENCE=aidw-backend
AUTH_ALGORITHMS=RS256
AUTH_JWKS_CACHE_TTL=3600
AUTH_ROLE_CLAIMS=roles,realm_access.roles,resource_access.{client_id}.roles
AUTH_GROUP_CLAIMS=groups
AUTH_DEV_ROLES=user

# ---------------------------------------------------------------------------
# Runtime behaviour (optional)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://frontend
# "inline" runs ingestion in the API (needs ENABLE_INAPI_EGRESS=true); "worker" enqueues only and
# the worker service (docker compose --profile worker) claims and executes.
INGEST_EXECUTOR=inline
ENABLE_INAPI_EGRESS=false
WORKER_POLL_SECONDS=5
WORKER_STALE_RUNNING_SECONDS=1800

# ---------------------------------------------------------------------------
# Governance — right-to-be-forgotten suppression pepper (#76)
# ---------------------------------------------------------------------------
# HMAC key that makes erased-subject hashes non-attributable (business keys are low-entropy, so a
# plain hash would be dictionary-reversible). It is the single bridge between an erasure and the
# ingest suppression filter that stops the erased subject from being re-ingested.
#
#   * REQUIRED to execute a deletion request. Erasure (request verification + execution) computes
#     this HMAC unconditionally to record the suppression entry, so it fails CLOSED with a loud
#     RuntimeError — never a silent partial erasure — whenever the pepper is unset.
#   * OPTIONAL for ordinary ingestion until the first erasure. The ingest filter loads a dataset's
#     suppression entries first and skips hashing entirely when there are none, so a deployment that
#     has never erased anything does not need the pepper. Once a dataset HAS suppression entries, the
#     ingest run fails CLOSED without the pepper — never a silent resurrection.
#   * The SAME value must be set for BOTH the backend and worker services.
#   * WRITE-ONCE. Rotating it orphans every existing suppression entry — previously-erased subjects
#     re-ingest on the next run and cannot be re-suppressed (the raw keys are gone by design).
#     Custody it offline like a database backup.
#
#   KNOWN GAP (#76 follow-up): post-ingest PROFILING (profile_source) does NOT yet consult the
#   suppression list. After an erasure NULLs a dataset's profile value-columns, the next profiling
#   pass re-samples the live source and can repopulate min/max/most_common with the erased subject's
#   values if the upstream source still holds them. Until profiling suppression lands, also erase
#   the subject at the source. See docs/BEHAVIORAL-ARCHITECTURE.md (Suppression).
#
# Generate:  openssl rand -base64 48
# Leave unset here; set it in your real `.env` (or the deployment secret store) when provisioning.
AIDW_SUPPRESSION_PEPPER=
